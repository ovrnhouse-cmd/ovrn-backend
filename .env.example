# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=VALUE
PGPASSWORD=VALUE
PGUSER=VALUE

# ─── Google OAuth2 ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=VALUE
GOOGLE_CLIENT_SECRET=VALUE

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=VALUE
CLOUDINARY_API_KEY=VALUE
CLOUDINARY_API_SECRET=VALUE

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=VALUE                  # base64-encoded, ≥ 256-bit key
JWT_EXPIRATION_MS=900000          # 15 min access token
JWT_REFRESH_EXPIRATION_MS=604800000 # 7 day refresh token

# ─── Razorpay ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=VALUE
RAZORPAY_KEY_SECRET=VALUE

# ─── CORS / Cookie / Frontend ─────────────────────────────────────────────────
# Local dev:
FRONTEND_REDIRECT_URL=http://localhost:3000/
CORS_ALLOWED_ORIGIN=http://localhost:3000
COOKIE_SECURE=false
COOKIE_DOMAIN=

# Production (api.ovrn.in + ovrn.in):
# SPRING_PROFILES_ACTIVE=prod
# FRONTEND_REDIRECT_URL=https://ovrn.in/
# CORS_ALLOWED_ORIGIN=https://ovrn.in
# COOKIE_SECURE=true
# COOKIE_DOMAIN=.ovrn.in           ← leading dot shares cookie across subdomains